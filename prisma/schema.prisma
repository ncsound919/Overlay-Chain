// ChainFlow - Supply Chain Management System Schema
// Enterprise-grade data model for global supply chain operations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("user") // admin, manager, analyst, viewer
  organizationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  organization  Organization? @relation(fields: [organizationId], references: [id])
  sessions      Session[]
  auditLogs     AuditLog[]
  
  @@index([email])
  @@index([organizationId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model Organization {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  type          String    @default("business") // enterprise, business, startup
  industry      String?
  website       String?
  settings      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  users         User[]
  suppliers     Supplier[]
  warehouses    Warehouse[]
  products      Product[]
  shipments     Shipment[]
  purchaseOrders PurchaseOrder[]
  demandForecasts DemandForecast[]
  
  @@index([slug])
}

// ============================================
// SUPPLY CHAIN NETWORK
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  code            String?
  type            String    @default("manufacturer") // manufacturer, distributor, raw_materials
  tier            Int       @default(2) // 1, 2, 3
  country         String?
  region          String?
  address         String?
  contactEmail    String?
  contactPhone    String?
  website         String?
  performanceScore Float?   @default(75.0)
  riskScore       Float?    @default(50.0)
  leadTimeDays    Int?
  paymentTerms    String?
  certifications  Json?
  metadata        Json?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  products        SupplierProduct[]
  purchaseOrders  PurchaseOrder[]
  performanceHistory SupplierPerformance[]
  riskEvents      RiskEvent[]
  
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([performanceScore])
  @@index([riskScore])
}

model SupplierProduct {
  id              String    @id @default(cuid())
  supplierId      String
  productId       String
  supplierSku     String?
  cost           Float?
  minOrderQty    Int?
  leadTimeDays   Int?
  qualityRating  Float?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  supplier        Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
}

model SupplierPerformance {
  id              String    @id @default(cuid())
  supplierId      String
  date            DateTime
  onTimeDelivery  Float?    // percentage
  qualityScore    Float?    // percentage
  responseTime    Float?    // hours
  fillRate        Float?    // percentage
  totalOrders     Int       @default(0)
  defectRate      Float?    // percentage
  notes           String?
  createdAt       DateTime  @default(now())
  
  supplier        Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  @@index([supplierId, date])
}

model Warehouse {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  code            String?
  type            String    @default("distribution") // distribution, fulfillment, manufacturing
  country         String?
  region          String?
  address         String?
  latitude        Float?
  longitude       Float?
  capacity        Int?      // square meters
  capacityUsed    Float?    // percentage
  isActive        Boolean   @default(true)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  inventory       Inventory[]
  
  @@unique([organizationId, code])
  @@index([organizationId])
}

// ============================================
// PRODUCT & INVENTORY
// ============================================

model Product {
  id              String    @id @default(cuid())
  organizationId  String
  sku             String
  name            String
  description     String?
  category        String?
  subcategory     String?
  unit            String    @default("each") // each, kg, liter, meter
  weight          Float?
  weightUnit      String?
  dimensions      Json?
  cost            Float?
  price           Float?
  isActive        Boolean   @default(true)
  attributes      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  supplierProducts SupplierProduct[]
  inventory       Inventory[]
  demandForecasts DemandForecast[]
  
  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([sku])
}

model Inventory {
  id              String    @id @default(cuid())
  warehouseId     String
  productId       String
  quantityOnHand  Int       @default(0)
  quantityReserved Int      @default(0)
  quantityIncoming Int      @default(0)
  reorderPoint    Int?
  reorderQuantity Int?
  lastStocktake   DateTime?
  location        String?   // bin/shelf location
  lotNumber       String?
  expirationDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([warehouseId, productId, lotNumber])
  @@index([warehouseId])
  @@index([productId])
}

// ============================================
// LOGISTICS & SHIPMENTS
// ============================================

model Shipment {
  id              String    @id @default(cuid())
  organizationId  String
  shipmentNumber  String
  type            String    @default("outbound") // inbound, outbound, transfer
  status          String    @default("pending") // pending, processing, shipped, in_transit, customs, delivered, cancelled
  mode            String    @default("sea") // sea, air, land, rail, multimodal
  originId        String?   // warehouse or location id
  originName      String?
  originCountry   String?
  destinationId   String?
  destinationName String?
  destinationCountry String?
  carrier         String?
  carrierTracking String?
  vesselName      String?
  vesselVoyage    String?
  estimatedDeparture DateTime?
  actualDeparture DateTime?
  estimatedArrival DateTime?
  actualArrival   DateTime?
  customsStatus   String?
  customsClearedAt DateTime?
  totalWeight     Float?
  totalVolume     Float?
  totalValue      Float?
  currency        String    @default("USD")
  incoterms       String?
  notes           String?
  blockchainTxId  String?   // Reference to blockchain transaction
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  trackingEvents  TrackingEvent[]
  items           ShipmentItem[]
  
  @@unique([organizationId, shipmentNumber])
  @@index([organizationId])
  @@index([status])
  @@index([carrierTracking])
}

model ShipmentItem {
  id              String    @id @default(cuid())
  shipmentId      String
  productId       String?
  productName     String?
  sku             String?
  quantity        Int
  unitValue       Float?
  totalValue      Float?
  weight          Float?
  dimensions      Json?
  lotNumber       String?
  createdAt       DateTime  @default(now())
  
  shipment        Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  @@index([shipmentId])
}

model TrackingEvent {
  id              String    @id @default(cuid())
  shipmentId      String
  timestamp       DateTime
  status          String
  location        String?
  latitude        Float?
  longitude       Float?
  description     String?
  source          String    @default("system") // system, carrier, manual, iot
  metadata        Json?
  createdAt       DateTime  @default(now())
  
  shipment        Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  @@index([shipmentId, timestamp])
}

// ============================================
// PROCUREMENT & ORDERS
// ============================================

model PurchaseOrder {
  id              String    @id @default(cuid())
  organizationId  String
  poNumber        String
  supplierId      String?
  status          String    @default("draft") // draft, submitted, confirmed, partial, received, cancelled
  orderDate       DateTime  @default(now())
  expectedDelivery DateTime?
  totalValue      Float?
  currency        String    @default("USD")
  paymentStatus   String    @default("pending")
  paymentTerms    String?
  notes           String?
  blockchainTxId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  
  @@unique([organizationId, poNumber])
  @@index([organizationId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String    @id @default(cuid())
  purchaseOrderId String
  productId       String?
  productName     String?
  sku             String?
  quantity        Int
  unitPrice       Float?
  totalPrice      Float?
  receivedQty     Int       @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  @@index([purchaseOrderId])
}

// ============================================
// DEMAND PLANNING & AI
// ============================================

model DemandForecast {
  id              String    @id @default(cuid())
  organizationId  String
  productId       String
  forecastDate    DateTime
  periodStart     DateTime
  periodEnd       DateTime
  predictedQty    Float
  confidence      Float?    // 0-100
  modelVersion    String?
  features        Json?     // Input features used
  actualQty       Float?    // Actual quantity (filled later)
  accuracy        Float?    // Forecast accuracy (filled later)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([organizationId, productId])
  @@index([periodStart, periodEnd])
}

// ============================================
// RISK & DISRUPTION
// ============================================

model RiskEvent {
  id              String    @id @default(cuid())
  organizationId  String?   // Can be system-wide or org-specific
  supplierId      String?
  type            String    // disruption, geopolitical, natural_disaster, financial, quality, cyber
  severity        String    @default("medium") // low, medium, high, critical
  title           String
  description     String?
  country         String?
  region          String?
  detectedAt      DateTime  @default(now())
  resolvedAt      DateTime?
  status          String    @default("active") // active, monitoring, resolved, dismissed
  impact          Json?     // Affected shipments, orders, etc.
  mitigation      String?
  source          String    @default("system") // system, news, manual, iot
  confidence      Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([detectedAt])
}

// ============================================
// BLOCKCHAIN & SMART CONTRACTS
// ============================================

model BlockchainTransaction {
  id              String    @id @default(cuid())
  txHash          String    @unique
  blockNumber     Int?
  network         String    @default("polygon") // ethereum, polygon, custom
  contractAddress String?
  method          String?
  fromAddress     String
  toAddress       String?
  value           Float?
  gasUsed         Int?
  gasPrice        Float?
  status          String    @default("pending") // pending, confirmed, failed
  payload         Json?
  entityType      String?   // shipment, po, payment
  entityId        String?
  timestamp       DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  @@index([txHash])
  @@index([entityType, entityId])
  @@index([status])
}

model SmartContract {
  id              String    @id @default(cuid())
  name            String
  address         String
  network         String    @default("polygon")
  abi             Json
  bytecode        String?
  type            String    @default("custom") // payment, escrow, supply_chain, custom
  description     String?
  isActive        Boolean   @default(true)
  deployedAt      DateTime?
  deployedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([address, network])
  @@index([network])
}

// ============================================
// AUDIT & COMPLIANCE
// ============================================

model AuditLog {
  id              String    @id @default(cuid())
  userId          String?
  action          String
  entityType      String
  entityId        String?
  oldValue        Json?
  newValue        Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  
  user            User?     @relation(fields: [userId], references: [id])
  
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Compliance {
  id              String    @id @default(cuid())
  type            String    // gdpr, soc2, iso27001, customs, import_export
  name            String
  description     String?
  status          String    @default("pending") // pending, certified, expired, revoked
  validFrom       DateTime?
  validUntil      DateTime?
  certificateUrl  String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([type])
  @@index([status])
}

// ============================================
// INTEGRATION & WEBHOOKS
// ============================================

model Integration {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  type            String    // erp, wms, tms, marketplace, carrier
  provider        String?   // sap, oracle, shopify, etc.
  status          String    @default("inactive") // active, inactive, error
  config          Json?     // Encrypted config
  lastSync        DateTime?
  syncStatus      String?
  errorCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([organizationId])
  @@index([type])
}

model Webhook {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  url             String
  events          Json      // Array of event types
  secret          String?
  isActive        Boolean   @default(true)
  lastTriggered   DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([organizationId])
  @@index([isActive])
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model SystemConfig {
  id              String    @id @default(cuid())
  key             String    @unique
  value           Json
  description     String?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([key])
}

model AIModel {
  id              String    @id @default(cuid())
  name            String
  type            String    // forecasting, classification, anomaly_detection, nlp
  version         String
  provider        String    @default("openai") // openai, anthropic, local
  config          Json?
  metrics         Json?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([name, version])
}
